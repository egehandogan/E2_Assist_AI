generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  gmailAccounts  GmailAccount[]
  tasks          Task[]
  meetings       Meeting[]
  notes          Note[]
  documents      Document[]
  chatSessions   ChatSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GmailAccount {
  id           String   @id @default(cuid())
  userId       String
  email        String
  accessToken  String
  refreshToken String?
  label        String?
  isActive     Boolean  @default(true)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails Email[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, email])
}

model Email {
  id             String   @id @default(cuid())
  gmailAccountId String
  gmailId        String
  threadId       String?
  from           String
  to             String
  subject        String
  snippet        String?
  body           String?
  summary        String?
  isRead         Boolean  @default(false)
  isStarred      Boolean  @default(false)
  labels         String?
  receivedAt     DateTime

  gmailAccount GmailAccount @relation(fields: [gmailAccountId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([gmailAccountId, gmailId])
}

model Meeting {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  location      String?
  googleEventId String?
  meetLink      String?
  attendees     String?
  status        String   @default("scheduled")
  notes         String?
  transcript    String?
  summary       String?
  aiJoined      Boolean  @default(false)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  meetingId   String?
  title       String
  description String?
  assignee    String?
  dueDate     DateTime?
  priority    String    @default("medium")
  status      String    @default("pending")
  category    String?
  reminder    Boolean   @default(true)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id      String  @id @default(cuid())
  userId  String
  title   String?
  content String
  source  String  @default("manual")
  tags    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id          String  @id @default(cuid())
  userId      String
  name        String
  type        String
  mimeType    String?
  size        Int?
  url         String?
  driveId     String?
  thumbnail   String?
  description String?
  tags        String?
  ocrText     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id       String  @id @default(cuid())
  userId   String
  title    String?
  model    String  @default("claude")
  messages String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
